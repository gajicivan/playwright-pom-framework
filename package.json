{
  "name": "otrs-e2e",
  "version": "1.0.0",
  "description": "Playwright + TypeScript E2E automation framework (Page Object Model). Demo target: OrangeHRM, structured to mirror coverage of an OTRS-like business application.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test --project=api",
    "test:chromium": "playwright test --project=chromium",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:ui": "playwright test --ui",
    "codegen": "playwright codegen https://opensource-demo.orangehrmlive.com/",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml}\"",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-plugin-playwright": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
