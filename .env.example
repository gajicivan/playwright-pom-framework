# Copy to .env and adjust per environment.
# .env is gitignored so credentials never get committed.

# Target environment: dev | staging | prod (here: a single public demo)
TEST_ENV=demo

# Base URL of the application under test
BASE_URL=https://opensource-demo.orangehrmlive.com

# Admin credentials (public demo defaults)
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=admin123

# Test execution
HEADLESS=true
SLOW_MO=0
